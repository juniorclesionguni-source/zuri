# Copia este ficheiro para .env.import (que o git ignora) e preenche os valores.
# Depois corre:  set -a && source .env.import && set +a && python scripts/pull_telegram_books.py --dry-run
#
# Para o --dry-run só precisas das 3 linhas do Telegram. As restantes só fazem falta
# na importação real (sem --dry-run).

# --- Telegram (my.telegram.org/apps) ---
TG_API_ID=
TG_API_HASH=
TG_CHANNEL=@o_teu_canal        # @username, link t.me/... ou id do canal

# --- Supabase (dashboard → Settings → API → service_role) ---
SUPABASE_URL=https://hdqluanhvokmeiwkdxzt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (dashboard → R2 → Manage API Tokens) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_EPUB_BUCKET=zuri-books
R2_COVER_BUCKET=zuri-epubs
